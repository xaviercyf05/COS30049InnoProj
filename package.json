  "version": "1.0.0",
  "description": "Basic Node.js + Express app with mobile-ready API and admin CRUD",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "seed:admin": "node scripts/seedAdmin.js",
    "seed:sample": "node scripts/seedSampleData.js",
    "seed:clear": "node scripts/clearSampleData.js",
    "mobile:start": "npm --prefix mobile run start",
    "mobile:android": "npm --prefix mobile run android",
    "mobile:ios": "npm --prefix mobile run ios",
    "mobile:web": "npm --prefix mobile run web",
    "test": "node --test"
  },
